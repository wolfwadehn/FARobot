        <mxCell id="40" value="9. link.IsColliding / mBoxVN.Color / tri.IsColliding set;  mGripper.Xfm = mTip.Xfm" style="rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;html=1;fontSize=11;align=left;spacingLeft=6;" vertex="1" parent="1"><mxGeometry x="635" y="455" width="310" height="26" as="geometry"/></mxCell>

        <mxCell id="41" value="Key: SetIKDisplay() updates IK sliders WITHOUT firing IKChanged — no round-trip IK→FK→IK loop." style="rounded=1;fillColor=#f8cecc;strokeColor=#b85450;html=1;fontSize=11;fontStyle=2;" vertex="1" parent="1"><mxGeometry x="20" y="520" width="590" height="26" as="geometry"/></mxCell>
