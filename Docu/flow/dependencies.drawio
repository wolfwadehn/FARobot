        <mxCell id="36" value="6. SetIKDisplay(tcp, rx,ry,rz)  [does NOT fire IKChanged]" style="html=1;endArrow=block;endFill=1;strokeColor=#333333;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="620" y="345" as="sourcePoint"/><mxPoint x="800" y="345" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="37" value="7. foreach joint → js.Refresh()  (FK sliders update to current angles)" style="html=1;endArrow=block;endFill=1;strokeColor=#333333;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="620" y="393" as="sourcePoint"/><mxPoint x="260" y="393" as="targetPoint"/></mxGeometry></mxCell>

        <mxCell id="38" value="8. CheckCollisions()  (link OBBs vs box OBB + triangle OBBs)" style="rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;html=1;fontSize=11;align=left;spacingLeft=6;" vertex="1" parent="1"><mxGeometry x="635" y="423" width="310" height="26" as="geometry"/></mxCell>
