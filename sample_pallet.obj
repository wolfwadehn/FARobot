# Sample pallet box for testing import (600 x 600 x 150 mm), placed in robot reach.
# Outward-wound triangles so face normals point away from the solid.
v 700 -300 0
v 1300 -300 0
v 1300 300 0
v 700 300 0
v 700 -300 150
v 1300 -300 150
v 1300 300 150
v 700 300 150
# top (+Z)
f 5 6 7
f 5 7 8
# bottom (-Z)
f 1 4 3
f 1 3 2
# front (-Y)
f 1 2 6
f 1 6 5
# back (+Y)
f 4 8 7
f 4 7 3
# left (-X)
f 1 5 8
f 1 8 4
# right (+X)
f 2 3 7
f 2 7 6
