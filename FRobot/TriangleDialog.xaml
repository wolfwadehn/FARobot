<Window x:Class="FRobot.TriangleDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Collision Triangle" Width="300" SizeToContent="Height"
        ResizeMode="NoResize" WindowStartupLocation="CenterScreen"
        Background="#252530" TextBlock.FontSize="13" TextBlock.Foreground="#E8E8F0">
   <Window.Resources>
      <Style TargetType="TextBox">
         <Setter Property="Background"    Value="#3A3A4C"/>
         <Setter Property="Foreground"    Value="#E8E8F0"/>
         <Setter Property="BorderBrush"   Value="#5A5A78"/>
         <Setter Property="BorderThickness" Value="1"/>
         <Setter Property="Padding"       Value="4,2"/>
         <Setter Property="Margin"        Value="2,2"/>
         <Setter Property="TextAlignment" Value="Right"/>
      </Style>
      <Style TargetType="Button">
         <Setter Property="Margin"      Value="4,0"/>
         <Setter Property="Padding"     Value="10,4"/>
         <Setter Property="Focusable"   Value="True"/>
         <Setter Property="Background"  Value="#444455"/>
         <Setter Property="Foreground"  Value="#E8E8F0"/>
         <Setter Property="BorderBrush" Value="#666680"/>
      </Style>
   </Window.Resources>
   <StackPanel Margin="16,12">

      <Grid Margin="0,0,0,10">
         <Grid.ColumnDefinitions>
            <ColumnDefinition/><ColumnDefinition Width="12"/><ColumnDefinition Width="100"/>
         </Grid.ColumnDefinitions>
         <StackPanel Grid.Column="0">
            <TextBlock Text="Name" Foreground="#8AB0E0" FontWeight="Bold" Margin="0,0,0,2"/>
            <TextBox x:Name="mName" Text="Triangle1" TextAlignment="Left"/>
         </StackPanel>
         <StackPanel Grid.Column="2">
            <TextBlock Text="Group" Foreground="#8AB0E0" FontWeight="Bold" Margin="0,0,0,2"/>
            <TextBox x:Name="mGroup" Text="Box" TextAlignment="Left"/>
         </StackPanel>
      </Grid>

      <Grid Margin="0,0,0,2">
         <Grid.ColumnDefinitions>
            <ColumnDefinition Width="24"/>
            <ColumnDefinition/><ColumnDefinition/><ColumnDefinition/>
         </Grid.ColumnDefinitions>
         <TextBlock Grid.Column="1" Text="X" HorizontalAlignment="Center" Foreground="#8AB0E0"/>
         <TextBlock Grid.Column="2" Text="Y" HorizontalAlignment="Center" Foreground="#8AB0E0"/>
         <TextBlock Grid.Column="3" Text="Z" HorizontalAlignment="Center" Foreground="#8AB0E0"/>
      </Grid>

      <Grid Margin="0,2">
         <Grid.ColumnDefinitions>
            <ColumnDefinition Width="24"/>
            <ColumnDefinition/><ColumnDefinition/><ColumnDefinition/>
         </Grid.ColumnDefinitions>
         <TextBlock Grid.Column="0" Text="P1" Foreground="#8AB0E0" VerticalAlignment="Center"/>
         <TextBox x:Name="mP1X" Text="1200" Grid.Column="1"/>
         <TextBox x:Name="mP1Y" Text="0"    Grid.Column="2"/>
         <TextBox x:Name="mP1Z" Text="300"  Grid.Column="3"/>
      </Grid>

      <Grid Margin="0,2">
         <Grid.ColumnDefinitions>
            <ColumnDefinition Width="24"/>
            <ColumnDefinition/><ColumnDefinition/><ColumnDefinition/>
         </Grid.ColumnDefinitions>
         <TextBlock Grid.Column="0" Text="P2" Foreground="#8AB0E0" VerticalAlignment="Center"/>
         <TextBox x:Name="mP2X" Text="1400" Grid.Column="1"/>
         <TextBox x:Name="mP2Y" Text="-300" Grid.Column="2"/>
         <TextBox x:Name="mP2Z" Text="600"  Grid.Column="3"/>
      </Grid>

      <Grid Margin="0,2">
         <Grid.ColumnDefinitions>
            <ColumnDefinition Width="24"/>
            <ColumnDefinition/><ColumnDefinition/><ColumnDefinition/>
         </Grid.ColumnDefinitions>
         <TextBlock Grid.Column="0" Text="P3" Foreground="#8AB0E0" VerticalAlignment="Center"/>
         <TextBox x:Name="mP3X" Text="1400" Grid.Column="1"/>
         <TextBox x:Name="mP3Y" Text="300"  Grid.Column="2"/>
         <TextBox x:Name="mP3Z" Text="600"  Grid.Column="3"/>
      </Grid>

      <Grid Margin="0,12,0,0">
         <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition Width="Auto"/>
         </Grid.ColumnDefinitions>
         <StackPanel Orientation="Horizontal" Grid.Column="0">
            <Button Content="Import CSV" Click="OnImport"/>
            <Button Content="Export CSV" Click="OnExport"/>
         </StackPanel>
         <StackPanel Orientation="Horizontal" Grid.Column="1">
            <Button Content="OK"     IsDefault="True" Click="OnOK"/>
            <Button Content="Cancel" IsCancel="True"/>
         </StackPanel>
      </Grid>
   </StackPanel>
</Window>
