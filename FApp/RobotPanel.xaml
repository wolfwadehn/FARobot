<UserControl x:Class="FApp.RobotPanel"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:FApp"
        Background="#252530" TextBlock.FontSize="13" TextBlock.Foreground="#E8E8F0">
   <UserControl.Resources>
      <!-- Converts double ↔ string for TextBox two-way bindings (handles both . and , decimal) -->
      <local:DoubleConverter x:Key="dc"/>

      <Style TargetType="Button">
         <Setter Property="Margin"      Value="4,2,4,2"/>
         <Setter Property="Padding"     Value="8,2,8,2"/>
         <Setter Property="Focusable"   Value="False"/>
         <Setter Property="Background"  Value="#444455"/>
         <Setter Property="Foreground"  Value="#E8E8F0"/>
         <Setter Property="BorderBrush" Value="#666680"/>
      </Style>
      <Style TargetType="TextBlock">
         <Setter Property="Foreground" Value="#E8E8F0"/>
      </Style>
      <Style TargetType="Slider" BasedOn="{StaticResource {x:Type Slider}}">
         <Setter Property="Margin" Value="4,1,4,4"/>
      </Style>

      <!-- Bold label at the top of each section -->
      <Style x:Key="SectionHeader" TargetType="TextBlock">
         <Setter Property="FontSize"   Value="13"/>
         <Setter Property="FontWeight" Value="Bold"/>
         <Setter Property="Foreground" Value="#A8B8D0"/>
         <Setter Property="Margin"     Value="8,10,0,4"/>
      </Style>
      <!-- Short label to the left of each slider (e.g. "X", "Rx", "BZ") -->
      <Style x:Key="SliderLabel" TargetType="TextBlock">
         <Setter Property="Width"             Value="22"/>
         <Setter Property="TextAlignment"     Value="Right"/>
         <Setter Property="VerticalAlignment" Value="Center"/>
         <Setter Property="Foreground"        Value="Silver"/>
      </Style>
      <!-- Editable textbox that mirrors the slider value -->
      <Style x:Key="SliderBox" TargetType="TextBox">
         <Setter Property="Width"             Value="55"/>
         <Setter Property="VerticalAlignment" Value="Center"/>
         <Setter Property="Margin"            Value="2,1,2,4"/>
         <Setter Property="Background"        Value="DimGray"/>
         <Setter Property="Foreground"        Value="WhiteSmoke"/>
         <Setter Property="BorderThickness"   Value="1"/>
         <Setter Property="TextAlignment"     Value="Right"/>
         <Setter Property="Padding"           Value="3,1,3,1"/>
      </Style>
   </UserControl.Resources>

   <ScrollViewer VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Disabled"
                 Background="#2A2A38">
      <StackPanel Margin="0,4,0,8">

         <!-- ── Forward Kinematics ──────────────────────────────────────── -->
         <!-- One slider row per joint, generated from the Joints collection -->
         <TextBlock Text="Forward Kinematics" Style="{StaticResource SectionHeader}"/>
         <ItemsControl ItemsSource="{Binding Joints}">
            <ItemsControl.ItemTemplate>
               <DataTemplate>
                  <StackPanel Orientation="Horizontal" Margin="4,0,4,2">
                     <TextBlock Text="{Binding Name}" Style="{StaticResource SliderLabel}"/>
                     <Slider Minimum="{Binding Min}" Maximum="{Binding Max}"
                             Value="{Binding Value, Mode=TwoWay}" MinWidth="130"/>
                     <TextBox Text="{Binding Value, Converter={StaticResource dc},
                                             Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              Style="{StaticResource SliderBox}"/>
                  </StackPanel>
               </DataTemplate>
            </ItemsControl.ItemTemplate>
         </ItemsControl>

         <!-- ── Inverse Kinematics ──────────────────────────────────────── -->
         <TextBlock Text="Inverse Kinematics" Style="{StaticResource SectionHeader}"/>
         <StackPanel Orientation="Horizontal" Margin="2,0,2,6">
            <Button Content="Home Position" Command="{Binding HomeCommand}"/>
            <Button Content="Set Home"      Click="OnSetHome"/>
         </StackPanel>

         <StackPanel Orientation="Horizontal" Margin="4,0,4,2">
            <TextBlock Text="X"  Style="{StaticResource SliderLabel}"/>
            <Slider Minimum="-2000" Maximum="3000" Value="{Binding X, Mode=TwoWay}" MinWidth="130"/>
            <TextBox Text="{Binding X,  Converter={StaticResource dc}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource SliderBox}"/>
         </StackPanel>
         <StackPanel Orientation="Horizontal" Margin="4,0,4,2">
            <TextBlock Text="Y"  Style="{StaticResource SliderLabel}"/>
            <Slider Minimum="-2000" Maximum="2000" Value="{Binding Y, Mode=TwoWay}" MinWidth="130"/>
            <TextBox Text="{Binding Y,  Converter={StaticResource dc}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource SliderBox}"/>
         </StackPanel>
         <StackPanel Orientation="Horizontal" Margin="4,0,4,2">
            <TextBlock Text="Z"  Style="{StaticResource SliderLabel}"/>
            <Slider Minimum="-1000" Maximum="3200" Value="{Binding Z, Mode=TwoWay}" MinWidth="130"/>
            <TextBox Text="{Binding Z,  Converter={StaticResource dc}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource SliderBox}"/>
         </StackPanel>
         <StackPanel Orientation="Horizontal" Margin="4,0,4,2">
            <TextBlock Text="Rx" Style="{StaticResource SliderLabel}"/>
            <Slider Minimum="-180" Maximum="180" Value="{Binding Rx, Mode=TwoWay}" MinWidth="130"/>
            <TextBox Text="{Binding Rx, Converter={StaticResource dc}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource SliderBox}"/>
         </StackPanel>
         <StackPanel Orientation="Horizontal" Margin="4,0,4,2">
            <TextBlock Text="Ry" Style="{StaticResource SliderLabel}"/>
            <Slider Minimum="-180" Maximum="180" Value="{Binding Ry, Mode=TwoWay}" MinWidth="130"/>
            <TextBox Text="{Binding Ry, Converter={StaticResource dc}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource SliderBox}"/>
         </StackPanel>
         <StackPanel Orientation="Horizontal" Margin="4,0,4,2">
            <TextBlock Text="Rz" Style="{StaticResource SliderLabel}"/>
            <Slider Minimum="-180" Maximum="180" Value="{Binding Rz, Mode=TwoWay}" MinWidth="130"/>
            <TextBox Text="{Binding Rz, Converter={StaticResource dc}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource SliderBox}"/>
         </StackPanel>

         <!-- ── Geometry & Objects ──────────────────────────────────────── -->
         <!-- Import one or more geometries; select one to move it (6 DOF) and  -->
         <!-- to edit/calibrate its user frame.                                -->
         <TextBlock Text="Geometry &amp; Objects" Style="{StaticResource SectionHeader}"/>
         <TextBlock Text="{Binding PalletStatus}" Margin="8,0,8,2" Foreground="Silver" TextWrapping="Wrap"/>
         <Button Content="Import Geometry…" HorizontalAlignment="Left" Margin="6,0,6,4" Click="OnImportPallet"/>
         <ComboBox Margin="6,0,6,4" ItemsSource="{Binding Objects}"
                   SelectedIndex="{Binding SelectedObject, Mode=TwoWay}" DisplayMemberPath="Name"/>

         <!-- Selected object: 6-DOF placement in world coords -->
         <TextBlock Text="Move selected (world mm / °)" Margin="8,2,8,2" Foreground="#8AB0E0"/>
         <StackPanel Orientation="Horizontal" Margin="4,0,4,1">
            <TextBlock Text="X"  Style="{StaticResource SliderLabel}"/>
            <Slider Minimum="-2000" Maximum="2000" Value="{Binding ObjX, Mode=TwoWay}" MinWidth="130"/>
            <TextBox Text="{Binding ObjX, Converter={StaticResource dc}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SliderBox}"/>
         </StackPanel>
         <StackPanel Orientation="Horizontal" Margin="4,0,4,1">
            <TextBlock Text="Y"  Style="{StaticResource SliderLabel}"/>
            <Slider Minimum="-2000" Maximum="2000" Value="{Binding ObjY, Mode=TwoWay}" MinWidth="130"/>
            <TextBox Text="{Binding ObjY, Converter={StaticResource dc}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SliderBox}"/>
         </StackPanel>
         <StackPanel Orientation="Horizontal" Margin="4,0,4,1">
            <TextBlock Text="Z"  Style="{StaticResource SliderLabel}"/>
            <Slider Minimum="-1000" Maximum="2000" Value="{Binding ObjZ, Mode=TwoWay}" MinWidth="130"/>
            <TextBox Text="{Binding ObjZ, Converter={StaticResource dc}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SliderBox}"/>
         </StackPanel>
         <StackPanel Orientation="Horizontal" Margin="4,0,4,1">
            <TextBlock Text="Rx" Style="{StaticResource SliderLabel}"/>
            <Slider Minimum="-180" Maximum="180" Value="{Binding ObjRx, Mode=TwoWay}" MinWidth="130"/>
            <TextBox Text="{Binding ObjRx, Converter={StaticResource dc}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SliderBox}"/>
         </StackPanel>
         <StackPanel Orientation="Horizontal" Margin="4,0,4,1">
            <TextBlock Text="Ry" Style="{StaticResource SliderLabel}"/>
            <Slider Minimum="-180" Maximum="180" Value="{Binding ObjRy, Mode=TwoWay}" MinWidth="130"/>
            <TextBox Text="{Binding ObjRy, Converter={StaticResource dc}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SliderBox}"/>
         </StackPanel>
         <StackPanel Orientation="Horizontal" Margin="4,0,4,1">
            <TextBlock Text="Rz" Style="{StaticResource SliderLabel}"/>
            <Slider Minimum="-180" Maximum="180" Value="{Binding ObjRz, Mode=TwoWay}" MinWidth="130"/>
            <TextBox Text="{Binding ObjRz, Converter={StaticResource dc}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SliderBox}"/>
         </StackPanel>

         <!-- Selected object: user frame, 6 parameters (world mm / °) -->
         <TextBlock Text="User frame (6 params)" Margin="8,6,8,2" Foreground="#8AB0E0"/>
         <Grid Margin="6,0,6,2">
            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
            <Grid.RowDefinitions><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
            <TextBox Grid.Row="0" Grid.Column="0" Text="{Binding FrX, Converter={StaticResource dc}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SliderBox}" Width="Auto"/>
            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding FrY, Converter={StaticResource dc}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SliderBox}" Width="Auto"/>
            <TextBox Grid.Row="0" Grid.Column="2" Text="{Binding FrZ, Converter={StaticResource dc}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SliderBox}" Width="Auto"/>
            <TextBox Grid.Row="1" Grid.Column="0" Text="{Binding FrRx, Converter={StaticResource dc}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SliderBox}" Width="Auto"/>
            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding FrRy, Converter={StaticResource dc}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SliderBox}" Width="Auto"/>
            <TextBox Grid.Row="1" Grid.Column="2" Text="{Binding FrRz, Converter={StaticResource dc}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SliderBox}" Width="Auto"/>
         </Grid>
         <StackPanel Orientation="Horizontal" Margin="2,0,2,4">
            <Button Content="Calibrate…"        Click="OnCalibrateFrame"/>
            <Button Content="Frame @ Corner"    Click="OnPickCorner"/>
            <Button Content="Clear"             Click="OnClearFrame"/>
         </StackPanel>

         <!-- ── Pick &amp; Place ─────────────────────────────────────────── -->
         <TextBlock Text="Pick &amp; Place" Style="{StaticResource SectionHeader}"/>
         <TextBlock Text="{Binding PickupStatus}" Margin="8,0,8,0" Foreground="Silver" TextWrapping="Wrap"/>
         <TextBlock Text="{Binding PlaceStatus}"  Margin="8,0,8,2" Foreground="Silver" TextWrapping="Wrap"/>
         <StackPanel Orientation="Horizontal" Margin="2,0,2,2">
            <Button Content="Pick Pickup Surface" Click="OnPickPickup"/>
            <Button Content="Pick Place Surface"  Click="OnPickPlace"/>
         </StackPanel>
         <Button Content="Generate Pick &amp; Place" HorizontalAlignment="Left"
                 Margin="6,0,6,4" Click="OnGenerateWaypoints"/>
         <TextBlock Text="{Binding PartStatus}" Margin="8,2,8,2" Foreground="Silver" TextWrapping="Wrap"/>
         <Button Content="Import Part…" HorizontalAlignment="Left" Margin="6,0,6,4" Click="OnImportPart"/>

         <!-- ── Obstacle ────────────────────────────────────────────────── -->
         <TextBlock Text="Obstacle" Style="{StaticResource SectionHeader}"/>
         <StackPanel Orientation="Horizontal" Margin="4,0,4,2">
            <TextBlock Text="BX" Style="{StaticResource SliderLabel}"/>
            <Slider Minimum="-1200" Maximum="1200" Value="{Binding BX, Mode=TwoWay}" MinWidth="130"/>
            <TextBox Text="{Binding BX, Converter={StaticResource dc}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource SliderBox}"/>
         </StackPanel>
         <StackPanel Orientation="Horizontal" Margin="4,0,4,2">
            <TextBlock Text="BY" Style="{StaticResource SliderLabel}"/>
            <Slider Minimum="-1200" Maximum="1200" Value="{Binding BY, Mode=TwoWay}" MinWidth="130"/>
            <TextBox Text="{Binding BY, Converter={StaticResource dc}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource SliderBox}"/>
         </StackPanel>
         <StackPanel Orientation="Horizontal" Margin="4,0,4,2">
            <TextBlock Text="BZ" Style="{StaticResource SliderLabel}"/>
            <Slider Minimum="0" Maximum="1500" Value="{Binding BZ, Mode=TwoWay}" MinWidth="130"/>
            <TextBox Text="{Binding BZ, Converter={StaticResource dc}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource SliderBox}"/>
         </StackPanel>

         <!-- ── Script ──────────────────────────────────────────────────── -->
         <TextBlock Text="Script" Style="{StaticResource SectionHeader}"/>
         <TextBox Margin="6,0,6,4"
                  Text="{Binding ScriptPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                  Background="DimGray" Foreground="WhiteSmoke"/>
         <StackPanel Orientation="Horizontal" Margin="2,0,2,2">
            <Button Content="Load"               Command="{Binding LoadCommand}"/>
            <Button Content="Add Waypoint"       Command="{Binding AddCommand}"/>
            <Button Content="{Binding PlayLabel}" Command="{Binding PlayCommand}"/>
         </StackPanel>
         <StackPanel Orientation="Horizontal" Margin="4,0,4,4">
            <TextBlock Text="WP" Style="{StaticResource SliderLabel}"/>
            <Slider Minimum="0" Maximum="{Binding WaypointMax}" MinWidth="130"
                    Value="{Binding WaypointPos, Mode=TwoWay}"
                    TickFrequency="1" TickPlacement="BottomRight" IsSnapToTickEnabled="False"/>
            <TextBox Text="{Binding WaypointPos, Converter={StaticResource dc}, Mode=OneWay}"
                     IsReadOnly="True" Style="{StaticResource SliderBox}"/>
         </StackPanel>
         <ItemsControl ItemsSource="{Binding Waypoints}">
            <ItemsControl.ItemTemplate>
               <DataTemplate>
                  <StackPanel Orientation="Horizontal" Margin="6,1,6,1">
                     <Button Content="{Binding Name}" Command="{Binding GoCommand}"
                             Width="54" HorizontalContentAlignment="Left"/>
                     <Button Content="{Binding Action}" Command="{Binding ActionCommand}"
                             Foreground="{Binding ActionBrush}" Width="64"/>
                     <Button Content="×" Command="{Binding RemoveCommand}" Padding="6,1" Margin="2"/>
                  </StackPanel>
               </DataTemplate>
            </ItemsControl.ItemTemplate>
         </ItemsControl>

         <!-- ── Collision Triangles ─────────────────────────────────────── -->
         <TextBlock Text="Collision Triangles" Style="{StaticResource SectionHeader}"/>
         <Button Content="Add Triangle…" HorizontalAlignment="Left"
                 Margin="6,0,6,6" Click="OnAddTriangle"/>
         <ItemsControl ItemsSource="{Binding Triangles}">
            <ItemsControl.ItemTemplate>
               <DataTemplate>
                  <StackPanel Orientation="Horizontal" Margin="6,2,6,2">
                     <TextBlock Text="{Binding Name}"  Width="110" VerticalAlignment="Center"
                                Foreground="Silver"/>
                     <TextBlock Text="{Binding Group}" Width="62"  VerticalAlignment="Center"
                                Foreground="{Binding GroupBrush}"/>
                     <Button Content="×" Padding="5,1" Margin="2"
                             Command="{Binding RemoveCommand}"/>
                  </StackPanel>
               </DataTemplate>
            </ItemsControl.ItemTemplate>
         </ItemsControl>

      </StackPanel>
   </ScrollViewer>
</UserControl>
