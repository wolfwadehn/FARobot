<Window x:Class="FApp.TcpOffsetDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TCP Offset" Width="260" SizeToContent="Height"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner"
        Background="#252530" TextBlock.FontSize="13" TextBlock.Foreground="#E8E8F0">
   <Window.Resources>
      <Style TargetType="TextBox">
         <Setter Property="Background"      Value="#3A3A4C"/>
         <Setter Property="Foreground"      Value="#E8E8F0"/>
         <Setter Property="BorderBrush"     Value="#5A5A78"/>
         <Setter Property="BorderThickness" Value="1"/>
         <Setter Property="Padding"         Value="4,2"/>
         <Setter Property="Margin"          Value="2,2"/>
         <Setter Property="TextAlignment"   Value="Right"/>
      </Style>
      <Style TargetType="Button">
         <Setter Property="Margin"      Value="4,0"/>
         <Setter Property="Padding"     Value="10,4"/>
         <Setter Property="Focusable"   Value="True"/>
         <Setter Property="Background"  Value="#444455"/>
         <Setter Property="Foreground"  Value="#E8E8F0"/>
         <Setter Property="BorderBrush" Value="#666680"/>
      </Style>
   </Window.Resources>
   <StackPanel Margin="16,12">

      <TextBlock Text="Position of TCP in wrist frame (mm)"
                 Foreground="#8AB0E0" FontWeight="Bold" Margin="0,0,0,10"/>

      <Grid Margin="0,0,0,2">
         <Grid.ColumnDefinitions>
            <ColumnDefinition Width="24"/>
            <ColumnDefinition/>
         </Grid.ColumnDefinitions>
         <TextBlock Grid.Column="0" Text="X" Foreground="#8AB0E0" VerticalAlignment="Center"/>
         <TextBox x:Name="mX" Grid.Column="1"/>
      </Grid>

      <Grid Margin="0,2">
         <Grid.ColumnDefinitions>
            <ColumnDefinition Width="24"/>
            <ColumnDefinition/>
         </Grid.ColumnDefinitions>
         <TextBlock Grid.Column="0" Text="Y" Foreground="#8AB0E0" VerticalAlignment="Center"/>
         <TextBox x:Name="mY" Grid.Column="1"/>
      </Grid>

      <Grid Margin="0,2">
         <Grid.ColumnDefinitions>
            <ColumnDefinition Width="24"/>
            <ColumnDefinition/>
         </Grid.ColumnDefinitions>
         <TextBlock Grid.Column="0" Text="Z" Foreground="#8AB0E0" VerticalAlignment="Center"/>
         <TextBox x:Name="mZ" Grid.Column="1"/>
      </Grid>

      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
         <Button Content="OK"     IsDefault="True" Click="OnOK"/>
         <Button Content="Cancel" IsCancel="True"/>
      </StackPanel>
   </StackPanel>
</Window>
