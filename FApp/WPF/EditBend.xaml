<Window x:Class="FApp.WPF.EditBend"
   xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
   xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
   xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
   xmlns:local="clr-namespace:FApp.WPF"
   mc:Ignorable="d"
   Title="Bend" ResizeMode="NoResize" SizeToContent="WidthAndHeight"
        ShowInTaskbar="False" WindowStartupLocation="CenterOwner">
   <StackPanel>
      <StackPanel.Resources>
         <ResourceDictionary>
            <Style TargetType="TextBox">
               <Setter Property="Width" Value="48px"/>
               <Setter Property="Padding" Value="0"/>
               <Setter Property="Margin" Value="0,2.4px"/>
            </Style>
            <Style TargetType="Label">
               <Setter Property="HorizontalContentAlignment" Value="Right"/>
            </Style>
            <Style TargetType="Button">
               <Setter Property="Margin" Value="2.4px"/>
            </Style>
            <Style TargetType="StackPanel">
               <Setter Property="Margin" Value="2.4px"/>
            </Style>
            <Style TargetType="Grid">
               <Setter Property="Margin" Value="2.4px"/>
            </Style>
         </ResourceDictionary>
      </StackPanel.Resources>
      <Grid>
         <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
         </Grid.RowDefinitions>
         <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
         </Grid.ColumnDefinitions>
         <Label Grid.Row="0" Grid.Column="0" Content="_Angle" />
         <TextBox x:Name="mAngleTB" Grid.Row="0" Grid.Column="1"/>
         <Label Grid.Row="1" Grid.Column="0" Content="_Radius" />
         <TextBox x:Name="mRadiusTB" Grid.Row="1" Grid.Column="1"/>
         <Label Grid.Row="2" Grid.Column="0" Content="_K-Factor" />
         <TextBox x:Name="mKFactorTB" Grid.Row="2" Grid.Column="1"/>
      </Grid>
      <Button x:Name="mFlipBtn" Content="Flip"/>
      <Button x:Name="mDeleteBtn" Content="Delete"/>
   </StackPanel>
</Window>
