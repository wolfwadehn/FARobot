<Window x:Class="FApp.RobotWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Robot" Width="320" SizeToContent="Height" ResizeMode="CanResizeWithGrip"
        Background="#252530" TextBlock.FontSize="13" TextBlock.Foreground="#E8E8F0"
        WindowStartupLocation="Manual">
   <Window.Resources>
      <Style TargetType="Button">
         <Setter Property="Margin"      Value="4,2,4,2"/>
         <Setter Property="Padding"     Value="8,2,8,2"/>
         <Setter Property="Focusable"   Value="False"/>
         <Setter Property="Background"  Value="#444455"/>
         <Setter Property="Foreground"  Value="#E8E8F0"/>
         <Setter Property="BorderBrush" Value="#666680"/>
      </Style>
      <Style TargetType="TextBlock">
         <Setter Property="Foreground" Value="#E8E8F0"/>
      </Style>
      <Style TargetType="Slider" BasedOn="{StaticResource {x:Type Slider}}">
         <Setter Property="Margin" Value="4,1,4,4"/>
      </Style>
   </Window.Resources>

   <ScrollViewer VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Disabled"
                 MaxHeight="800"
                 Background="#2A2A38">
      <StackPanel Name="mPanel" Margin="0,4,0,8"/>
   </ScrollViewer>
</Window>
