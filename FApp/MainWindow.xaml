<Window x:Class="FApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" Background="#9898A0"
        Title="FApp" d:Height="450" d:Width="800" WindowState="Maximized"
        TextBlock.FontSize="13">
   <DockPanel>
      <Menu DockPanel.Dock="Top" Margin="0,0,0,4" FontSize="13" Background="#C8C8D0" IsTabStop="False">
         <MenuItem Header="_File" IsTabStop="False">
            <MenuItem Header="E_xit" Click="Exit" IsTabStop="False"/>
         </MenuItem>
         <MenuItem Header="_View" IsTabStop="False">
            <MenuItem Header="Zoom _Extents" Click="ZoomExtents" IsTabStop="False"/>
            <Separator/>
            <MenuItem Header="_Robot..." Click="OpenRobot" IsTabStop="False"/>
            <MenuItem Header="Robot _Home" Click="RobotHome" IsTabStop="False"/>
            <MenuItem Header="TCP _Legend..." Click="TcpLegend" IsTabStop="False"/>
         </MenuItem>
         <MenuItem Header="About!" Click="About" IsTabStop="False"/>
      </Menu>
      <Border DockPanel.Dock="Left" Name="mToolbarHost" Width="27" Padding="2,4,0,0" Margin="0,0,4,0" Background="#C8C8D0"/>
      <Border Name="mContent" Background="#C8C8D0" />
   </DockPanel>
</Window>
